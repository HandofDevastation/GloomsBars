<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
    <Frames>
        <Frame name="MyAddonFrame" parent="UIParent">
            <Size>
                <AbsDimension x="200" y="40"/>
            </Size>
            <Anchors>
                <Anchor point="CENTER" relativeTo="UIParent" relativePoint="CENTER">
                    <Offset>
                        <AbsDimension x="0" y="100"/>
                    </Offset>
                </Anchor>
            </Anchors>
            <Frames>
                <StatusBar name="MyAddonHealthBar" parentKey="healthBar">
                    <Size>
                        <AbsDimension x="200" y="20"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="MyAddonFrame" relativePoint="TOPLEFT">
                            <Offset>
                                <AbsDimension x="0" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Layer level="ARTWORK">
                        <Texture parentKey="barTexture" file="Interface\Buttons\WHITE8X8"/>
                    </Layer>
                    <Scripts>
                        <OnLoad>
                            MyAddonHealthBar_OnLoad(self)
                        </OnLoad>
                    </Scripts>
                </StatusBar>
            </Frames>
            <Scripts>
                <OnLoad>
                    MyAddonFrame_OnLoad(self)
                </OnLoad>
            </Scripts>
        </Frame>
    </Frames>
</Ui>
